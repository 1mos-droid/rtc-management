rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user authenticated?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Get user data from our users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email)).data;
    }

    // Helper: Has a specific role?
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    // Helper: Is Admin?
    function isAdmin() {
      return hasRole('admin');
    }

    // Helper: Is Branch Admin for a specific branch?
    function isBranchAdmin(branch) {
      return hasRole('branch_admin') && getUserData().branch == branch;
    }

    // --- COLLECTION RULES ---

    // Users Collection: Secure metadata
    match /users/{email} {
      allow read: if isAuthenticated() && (request.auth.token.email == email || isAdmin());
      allow write: if isAdmin(); // Only super admins can grant/revoke access levels
    }

    // Members Collection
    match /members/{memberId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isBranchAdmin(request.resource.data.branch);
      allow delete: if isAdmin();
    }

    // Transactions Collection
    match /transactions/{txId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isBranchAdmin(request.resource.data.category);
      allow delete: if isAdmin();
    }

    // Events Collection
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isBranchAdmin(request.resource.data.branch);
      allow delete: if isAdmin();
    }

    // Attendance Collection
    match /attendance/{recordId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isBranchAdmin(request.resource.data.branch);
      allow delete: if isAdmin();
    }

    // Bible Studies & Resources
    match /bible-studies/{studyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /resources/{resId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
